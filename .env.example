# Example environment for shiz_book.
# Copy to .env and replace placeholders with real values.
# Never commit .env or real secrets.

# JWT settings. JWT_SECRET is required.
JWT_SECRET=replace-with-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Postgres settings for users, roles, audit log and auth.
DATABASE_URL=
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=shiz_book
POSTGRES_USER=shiz_book
POSTGRES_PASSWORD=replace-with-postgres-password

# First-run superadmin bootstrap. Set all three together or leave all empty.
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_EMAIL=superadmin@example.com
SUPERADMIN_PASSWORD=replace-with-superadmin-password

# Mongo settings for feed, events, votes and comments.
MONGO_URL=
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_DB=shiz_book
MONGO_INITDB_ROOT_USERNAME=shiz_book
MONGO_INITDB_ROOT_PASSWORD=replace-with-mongo-password
